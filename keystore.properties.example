# Copie ce fichier en `keystore.properties` (gitignoré) pour signer un build
# release EN LOCAL. En CI, ces valeurs viennent des secrets GitHub via des
# variables d'environnement (KEYSTORE_FILE / KEYSTORE_PASSWORD / KEY_ALIAS /
# KEY_PASSWORD) — voir .github/workflows/release.yml.
#
# Ne JAMAIS committer keystore.properties ni le .jks.

storeFile=C:/chemin/vers/yomikata-release.jks
storePassword=motDePasseDuKeystore
keyAlias=aliasDeLaCle
keyPassword=motDePasseDeLAlias
